{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/ai",
      "destination": "/api/ai.js"
    },
    {
      "source": "/api/me",
      "destination": "/api/me.js"
    },
    {
      "source": "/api/user-profile",
      "destination": "/api/user-profile.js"
    },
    {
      "source": "/api/assignment",
      "destination": "/api/assignment.js"
    },
    {
      "source": "/api/validate-referral",
      "destination": "/api/validate-referral.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
     {
      "source": "/api/admin-login",
      "destination": "/api/admin-login.js"
    },
     {
      "source": "/api/messages",
      "destination": "/api/messages.js"
    },
     {
      "source": "/api/all-messages",
      "destination": "/api/all-messages.js"
    }
    
    
    
  ]
}